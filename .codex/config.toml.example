# Template local do Codex. Copie para .codex/config.toml, que e gitignored.
# O Hostinger le o token do .env; cole o token Coolify somente na copia gitignored.
# O Meta DevTools autentica por OAuth (codex mcp login meta-devtools) — nao ha token no arquivo.

[mcp_servers.hostinger-vps]
command = "npx"
args = ["-y", "--package", "hostinger-api-mcp@0.2.5", "hostinger-vps-mcp"]
startup_timeout_sec = 30
default_tools_approval_mode = "prompt"

[mcp_servers.coolify]
command = "npx"
args = ["-y", "@masonator/coolify-mcp@2.12.0"]
startup_timeout_sec = 30
default_tools_approval_mode = "prompt"

[mcp_servers.coolify.env]
COOLIFY_BASE_URL = "https://vps.panlabs.tech"
COOLIFY_ACCESS_TOKEN = "<COLE_O_TOKEN_DO_COOLIFY>"

[mcp_servers.cloudflare]
url = "https://mcp.cloudflare.com/mcp"
default_tools_approval_mode = "prompt"

[mcp_servers.meta-devtools]
url = "https://mcp.facebook.com/devtools"
default_tools_approval_mode = "prompt"
