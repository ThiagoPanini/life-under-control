# Variables required by luc-api. In dev, copy to .env (gitignored); in
# production, set them on Coolify. No real value ever enters git.

# Shared secret of the internal JWT minted by the BFF (HS256, iss=luc-web,
# aud=luc-api). Generate with: openssl rand -hex 32. Never reuse AUTH_SECRET.
LUC_INTERNAL_JWT_SECRET=
